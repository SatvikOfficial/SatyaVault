# Public values (safe to expose in browser bundle)
# Polygon Amoy RPC endpoint (Alchemy/Infura/QuickNode or public RPC)
NEXT_PUBLIC_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# SatyaVault contract deployed on Polygon Amoy
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Public base URL used to build verification links in QR packets
# Local: http://localhost:3000
# Production: https://your-domain.example
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Server-only values (never expose in frontend code)
# Pinata JWT with pinFileToIPFS permission
PINATA_JWT=PASTE_PINATA_JWT_HERE

# Secret used to sign QR verification tokens (minimum 32 chars)
# Generate with: openssl rand -base64 48
QR_TOKEN_SECRET=PASTE_STRONG_RANDOM_SECRET_HERE

# Optional: first block to start indexer sync from (deployment block number)
# CHAIN_SYNC_START_BLOCK=0
