# Hardhat deployment configuration (root project)

# Polygon Amoy RPC URL from your node provider
# Example: https://polygon-amoy.g.alchemy.com/v2/<api_key>
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Private key for deployment wallet (testnet wallet only)
# Keep the 0x prefix. Never commit this value.
DEPLOYER_PRIVATE_KEY=0xPASTE_DEPLOYER_PRIVATE_KEY_HERE

# Contract address used by bootstrap role script after deployment.
# Set this once deploy command returns contract address.
CONTRACT_ADDRESS=0xPASTE_DEPLOYED_CONTRACT_ADDRESS_HERE

# Optional role bootstrap addresses (all testnet wallets).
# New names:
INVESTIGATOR_WALLET=0xPASTE_INVESTIGATOR_WALLET
FSL_OFFICER_WALLET=0xPASTE_FSL_OFFICER_WALLET
COURT_OFFICER_WALLET=0xPASTE_COURT_OFFICER_WALLET
AUDITOR_WALLET=0xPASTE_AUDITOR_WALLET
MINISTRY_ADMIN_WALLET=0xPASTE_MINISTRY_ADMIN_WALLET

# Backward-compatible legacy aliases (optional)
# POLICE_WALLET=0xPASTE_POLICE_WALLET
# FSL_WALLET=0xPASTE_FSL_WALLET
# COURT_WALLET=0xPASTE_COURT_WALLET

# Optional: transfer admin ownership to MINISTRY_ADMIN_WALLET during bootstrap.
# TRANSFER_ADMIN=true
