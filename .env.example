# Polygon Amoy RPC URL from Alchemy / Infura
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Wallet private key used ONLY for deployment (never for app users)
# KEEP THIS ONLY IN LOCAL .env (DO NOT COMMIT REAL VALUE)
# How to get it:
# 1) Create a fresh TEST wallet in MetaMask (Polygon Amoy) and fund it with a bit of test MATIC.
# 2) In MetaMask: Account details → Export private key → copy the 64‑hex string.
# 3) Paste it into your local `.env` at project root as a single line, e.g.:
#      DEPLOYER_PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
#      DEPLOYER_PRIVATE_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
#    (both forms are accepted; Hardhat will ignore invalid shapes)
# NEVER use your main wallet here.
DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Contract address (filled after deployment)
SATYAVAULT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Pinata credentials for IPFS upload
PINATA_JWT=YOUR_PINATA_JWT_HERE
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# Optional role bootstrap addresses (testnet wallets)
INVESTIGATOR_WALLET=0xPASTE_INVESTIGATOR_WALLET
FSL_OFFICER_WALLET=0xPASTE_FSL_OFFICER_WALLET
COURT_OFFICER_WALLET=0xPASTE_COURT_OFFICER_WALLET
AUDITOR_WALLET=0xPASTE_AUDITOR_WALLET
MINISTRY_ADMIN_WALLET=0xPASTE_MINISTRY_ADMIN_WALLET

# Optional: transfer admin to MINISTRY_ADMIN_WALLET after bootstrap
# TRANSFER_ADMIN=true
