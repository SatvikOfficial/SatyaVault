{
  "name": "satyavault",
  "version": "1.0.0",
  "description": "SatyaVault - Immutable Chain-of-Custody for Digital Evidence",
  "private": true,
  "scripts": {
    "compile": "HARDHAT_DISABLE_TELEMETRY=1 hardhat compile",
    "test": "HARDHAT_DISABLE_TELEMETRY=1 hardhat test",
    "deploy:amoy": "HARDHAT_DISABLE_TELEMETRY=1 hardhat run scripts/deploy.js --network amoy",
    "bootstrap:roles": "HARDHAT_DISABLE_TELEMETRY=1 hardhat run scripts/bootstrapRoles.js --network amoy"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.10"
  }
}
